--- !u!114 &116805985
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 116805984}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 9b8dbb842ef11464988ac620984012a5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  dialogeSettings:
  - dialogeText: "\u041E, \u043F\u0440\u0438\u0432\u0435\u0442 \u043D\u043E\u0432\u0438\u0447\u043E\u043A!
      \u0422\u044B \u0435\u0449\u0451 \u043D\u0435 \u043F\u043E\u043D\u044F\u043B
      \u043A\u0443\u0434\u0430 \u043F\u043E\u043F\u0430\u043B?"
    dialogeAuthor: "\u0427\u0438\u043F\u043F\u0438"
    dialogeSprite: {fileID: 21300000, guid: b8e38e75e6a7f4f468c79e5b987a0248, type: 3}
    dialogeTime: 6
  - dialogeText: "\u0422\u044B \u0434\u043E\u043B\u0436\u0435\u043D \u0431\u0443\u0434\u0435\u0448\u044C
      \u0411\u0415\u0421\u041A\u041E\u041D\u0415\u0427\u041D\u041E \u043F\u0443\u0442\u0435\u0448\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u0442\u044C
      \u043F\u043E \u0440\u0430\u0437\u043D\u044B\u043C \u043C\u0443\u043B\u044C\u0442\u0438\u0432\u0441\u0435\u043B\u0435\u043D\u043D\u044B\u043C
      \u0432 \u043F\u043E\u0438\u0441\u043A\u0430\u0445 \u043F\u0440\u0438\u0433\u043E\u0434\u043D\u044B\u0445
      \u0434\u043B\u044F \u0436\u0438\u0437\u043D\u0438 :)"
    dialogeAuthor: "\u0427\u0438\u043F\u043F\u0438"
    dialogeSprite: {fileID: 21300000, guid: b8e38e75e6a7f4f468c79e5b987a0248, type: 3}
    dialogeTime: 6
  - dialogeText: "\u041D\u0443-\u0441, \u044F \u0442\u0443\u0442 \u043D\u0435 \u0447\u0442\u043E\u0431\u044B
      \u0441 \u0442\u043E\u0431\u043E\u0439 \u0433\u043E\u0432\u043E\u0440\u0438\u0442\u044C,
      \u043F\u043E\u044D\u0442\u043E\u043C\u0443 \u043F\u0440\u0438\u0441\u0442\u0443\u043F\u0438\u043C
      \u043A \u043E\u0431\u0443\u0447\u0435\u043D\u0438\u044E"
    dialogeAuthor: "\u0427\u0438\u043F\u043F\u0438"
    dialogeSprite: {fileID: 21300000, guid: b8e38e75e6a7f4f468c79e5b987a0248, type: 3}
    dialogeTime: 6
  - dialogeText: "\u041D\u0430\u0436\u043C\u0438 Escape, \u043E\u0442\u043A\u0440\u043E\u0439
      \u043F\u0440\u0435\u0434\u043C\u0435\u0442\u044B \u0438 \u0432\u044B\u0431\u0435\u0440\u0438
      \u0441\u0442\u043E\u043B."
    dialogeAuthor: "\u0427\u0438\u043F\u043F\u0438"
    dialogeSprite: {fileID: 21300000, guid: b8e38e75e6a7f4f468c79e5b987a0248, type: 3}
    dialogeTime: 10
