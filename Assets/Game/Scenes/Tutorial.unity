--- !u!114 &2096893213
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 2096893211}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 9b8dbb842ef11464988ac620984012a5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  dialogeSettings:
  - dialogeText: "\u0419\u043E\u0443, \u043C\u043E\u043B\u043E\u0434\u0435\u0446!"
    dialogeAuthor: "\u0427\u0438\u043F\u043F\u0438"
    dialogeSprite: {fileID: 21300000, guid: b8e38e75e6a7f4f468c79e5b987a0248, type: 3}
    dialogeTime: 4
  - dialogeText: "\u0422\u0435\u043F\u0435\u0440\u044C \u0442\u044B \u0432\u043B\u0430\u0434\u0435\u0435\u0448\u044C
      \u0442\u0430\u0439\u043D\u044B\u043C \u043D\u0430\u0432\u044B\u043A\u043E\u043C
      \u0441\u0442\u043E\u043B\u043E\u0432!"
    dialogeAuthor: "\u0427\u0438\u043F\u043F\u0438"
    dialogeSprite: {fileID: 21300000, guid: b8e38e75e6a7f4f468c79e5b987a0248, type: 3}
    dialogeTime: 4
  - dialogeText: "\u0416\u0430\u043B\u044C, \u0447\u0442\u043E \u0442\u0443\u0442
      \u043E\u043D\u0438 \u043D\u0435 \u043F\u043E\u043C\u043E\u0433\u0443\u0442...
      \u0412\u043F\u0435\u0440\u0435\u0434\u0438 \u0441\u0442\u0435\u043D\u0430,
      \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u043D\u0430\u043D\u043E\u0441\u0438\u0442
      \u0440\u043E\u0432\u043D\u043E 100 \u0435\u0434\u0435\u043D\u0438\u0446 \u0443\u0440\u043E\u043D\u0430"
    dialogeAuthor: "\u0427\u0438\u043F\u043F\u0438"
    dialogeSprite: {fileID: 21300000, guid: b8e38e75e6a7f4f468c79e5b987a0248, type: 3}
    dialogeTime: 8
  - dialogeText: "\u041D\u043E, \u044F \u0437\u043D\u0430\u044E \u0447\u0442\u043E
      \u0442\u0435\u0431\u0435 \u0434\u0435\u043B\u0430\u0442\u044C!"
    dialogeAuthor: "\u0427\u0438\u043F\u043F\u0438"
    dialogeSprite: {fileID: 21300000, guid: b8e38e75e6a7f4f468c79e5b987a0248, type: 3}
    dialogeTime: 4
  - dialogeText: "\u0422\u043E\u0447\u043D\u043E \u0442\u0430\u043A\u0436\u0435 \u0432\u043E\u0437\u044C\u043C\u0438
      \u044D\u0433\u0433\u043E\u043B\u043B\u0443 \u0438 \u0432\u044B\u043F\u0435\u0439
      (F)!"
    dialogeAuthor: "\u0427\u0438\u043F\u043F\u0438"
    dialogeSprite: {fileID: 21300000, guid: b8e38e75e6a7f4f468c79e5b987a0248, type: 3}
    dialogeTime: 4
