--- !u!114 &568433956274852871
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 4727962089303199776}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 21e34a74deb74924a8cc6e581b637436, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  texts:
  - "\u0425\u043B\u0435\u0431 \u0438\u043C\u0431\u0430"
  - "\u0421\u0442\u043E\u043B \u0441\u044A\u0435\u0434\u043E\u0431\u0435\u043D"
  - "\u0414\u0430 \u043D\u0435 \u0431\u0443\u0434\u0435\u0442 \u0442\u0443\u0442
    \u043D\u043E\u0440\u043C \u0441\u043E\u0432\u0435\u0442\u043E\u0432, \u0427\u0438\u043F\u043F\u0438
    \u0443\u0441\u0442\u0430\u043B!"
  - "\u0412\u0430\u043D\u043D\u0430\u043B\u0451\u0442 \u043A\u0440\u0443\u0442\u043E\u0439"
  - "\u041D\u0430\u0436\u0438\u043C\u0430\u044F Escape \u0432\u044B \u0441\u0431\u0440\u0430\u0441\u044B\u0432\u0430\u0435\u0442\u0435
    \u0438\u043D\u0435\u0440\u0446\u0438\u044E \u043F\u043E\u043B\u0451\u0442\u0430"
  - "\u0427\u0442\u043E\u0431\u044B \u0443\u0431\u0438\u0442\u044C DummyPlayer \u043F\u043E\u0441\u0442\u0430\u0432\u044C\u0442\u0435
    \u0433\u0430\u043B\u043E\u0447\u043A\u0443 \"\u0423\u0434\u0430\u043B\u044F\u0435\u0442\u0441\u044F
    \u043B\u0438 \u043E\u0431\u044A\u0435\u043A\u0442?\" \u0432 \u0440\u0435\u0434\u0430\u043A\u0442\u043E\u0440\u0435
    \u043A\u0430\u0440\u0442"
  - "\u0421\u0442\u043E\u043B \u043C\u043E\u0436\u043D\u043E \u0443\u0431\u0438\u0442\u044C"
  textTMP: {fileID: 7466378167894298648}
